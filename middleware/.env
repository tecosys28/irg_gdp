# ─── IRG Chain 888101 middleware (GDP copy) ──────────────────────────────────
# Copy of .env.example with deployment values.
# DO NOT commit secrets to git — use GCP Secret Manager or AWS KMS in prod.

PORT=3100
LOG_LEVEL=info

# Besu RPC — internal cluster DNS if deployed on the same EKS/GKE namespace.
# For Cloud Run: use the internal VPC address of the Besu cluster.
BESU_RPC=http://43.205.237.197:8545
IRG_CHAIN_ID=888101

# Shared HMAC secret between Django and this middleware.
# Must match IRG_CHAIN_MIDDLEWARE_SECRET in the Django environment.
# Generate: openssl rand -hex 32
MIDDLEWARE_SHARED_SECRET=

# System signer key — loaded once at startup, never logged, never accepted
# from HTTP callers. Load from AWS Secrets Manager / GCP Secret Manager in prod.
# In local dev only, you may paste a hex private key here temporarily.
SYSTEM_SIGNER_KEY=

# Django audit sink — this middleware POSTs every confirmed tx here.
# Must match AUDIT_SINK_URL in the Django BLOCKCHAIN_CONFIG.
AUDIT_SINK_URL=https://REPLACE_WITH_RENDER_URL/api/v1/chain/audit/
AUDIT_SINK_TOKEN=

# CORS — only needed if browser clients talk directly to this middleware.
# Normal path is: browser → Django → middleware (no browser CORS needed).
CORS_ORIGINS=
