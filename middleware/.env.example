# ─── IRG Chain 888101 middleware (GDP copy) ──────────────────────────────────
# This middleware runs alongside the Django backend. Mirrored copy exists
# inside irg-ftr-platform-v5/middleware/ — deploy whichever one is reachable
# from both apps (only ONE instance needs to be live per environment).

PORT=3100
LOG_LEVEL=info

# Besu RPC — internal cluster DNS if deployed on the same EKS namespace,
# else the public TLS endpoint.
BESU_RPC=http://irg-rpc-service:8545
IRG_CHAIN_ID=888101

# Shared secret for HMAC auth between Django and this middleware.
# Generate with: openssl rand -hex 32
MIDDLEWARE_SHARED_SECRET=

# System signer for backend-originated transactions (corpus, oracle, recall,
# governance execution). Load from AWS Secrets Manager / KMS — do NOT commit
# a raw key. In local dev you may paste a hex private key here temporarily.
SYSTEM_SIGNER_KEY=

# Audit sink — Django endpoint that receives every submitted tx for
# durable DB storage. Leave blank to disable (dev only).
AUDIT_SINK_URL=http://django-backend:8000/api/v1/chain/audit/
AUDIT_SINK_TOKEN=

# CORS (comma-separated). Only needed if browser clients talk directly
# to this middleware; normal path is browser -> Django -> middleware.
CORS_ORIGINS=
