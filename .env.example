# ─── Chain (read-only connection to irg_chain 888101) ───────────────────────
BLOCKCHAIN_RPC=http://localhost:8545
# Production: BLOCKCHAIN_RPC=http://43.205.237.197:8545

# ─── Middleware (Django → Node.js → Besu relay) ──────────────────────────────
# URL of the irg_gdp/middleware/server.js process
IRG_CHAIN_MIDDLEWARE_URL=http://localhost:3100
# Generate with: openssl rand -hex 32
# Must match MIDDLEWARE_SHARED_SECRET in middleware/.env
IRG_CHAIN_MIDDLEWARE_SECRET=
# Bearer token the middleware uses when posting audit callbacks to Django
IRG_CHAIN_AUDIT_TOKEN=
# Set to False in production — prevents silent simulation when middleware is down
IRG_CHAIN_ALLOW_SIMULATE=True

# ─── ABI directory (points at irg_chain/abis/ after running export-abis.js) ─
# e.g.: IRG_CHAIN_ABI_DIR=/opt/irg_chain/abis
IRG_CHAIN_ABI_DIR=

