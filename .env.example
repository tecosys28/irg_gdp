# ═════════════════════════════════════════════════════════════════════════════
# irg_gdp — Environment Configuration (copy to .env.local / .env.production)
# ═════════════════════════════════════════════════════════════════════════════

# ─── Firebase (this project's own — irg-gdp-prod) ───────────────────────────
FIREBASE_PROJECT_ID=irg-gdp-prod
# Either provide a path …
GOOGLE_APPLICATION_CREDENTIALS=/secrets/irg-gdp-prod-service-account.json
# … or provide the raw JSON in an env var (Cloud Run / GitHub Actions)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── Django ─────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=gdp.irgecosystem.com,irg-gdp-api-xxxxxx-el.a.run.app

# ─── Database (Postgres or Cloud SQL) ───────────────────────────────────────
DATABASE_URL=postgres://irg_gdp:secret@127.0.0.1:5432/irg_gdp

# ─── Redis / Celery (optional) ──────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── Chain (read-only connection to irg_chain) ──────────────────────────────
CHAIN_RPC_URL=https://rpc.irg-chain-prod.cloudfunctions.net
