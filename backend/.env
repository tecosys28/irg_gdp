# ─── IRG_GDP Backend Environment ─────────────────────────────────────────────
# EC2 instance: 43.205.237.197
# SSH: ssh -i C:\keys\irg-key.pem ec2-user@43.205.237.197

# ── IRG Chain 888101 ──────────────────────────────────────────────────────────
BESU_RPC=http://43.205.237.197:8545
IRG_CHAIN_ID=888101
IRG_CHAIN_MIDDLEWARE_URL=http://43.205.237.197:3100
IRG_CHAIN_MIDDLEWARE_SECRET=your-32-char-secret
IRG_CHAIN_ALLOW_SIMULATE=false

# ── Contract Addresses (fill after deploying Solidity contracts) ──────────────
ADDR_TGDP_MINTING=
ADDR_FTR_REDEMPTION=
ADDR_P2P_SETTLEMENT=
ADDR_SUPER_CORPUS=
ADDR_GOVERNANCE=
ADDR_DISPUTE_REGISTRY=
ADDR_LBMA_ORACLE=
ADDR_RECALL_REGISTRY=
ADDR_JR_REGISTRY=
ADDR_JDB_REGISTRY=
ADDR_GIC_LEDGER=
ADDR_IDENTITY_REGISTRY=
ADDR_IPR_LICENSE=
ADDR_DEVICE_P2P=
ADDR_WALLET_RECOVERY_EVENTS=

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_DEBUG=False
# EC2 IP + localhost for health checks from the load balancer / Firebase proxy.
# Add your domain (e.g. irggdp.com) once DNS is pointed here.
DJANGO_ALLOWED_HOSTS=43.205.237.197,localhost,127.0.0.1
# REQUIRED in production — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
FIREBASE_PROJECT_ID=irggdp
# Path to Firebase service-account JSON (or set FIREBASE_CREDENTIALS_JSON env var as JSON string)
# GOOGLE_APPLICATION_CREDENTIALS=/etc/irg/firebase-credentials.json

# ── Audit sink token (must match middleware AUDIT_SINK_TOKEN) ─────────────────
IRG_CHAIN_AUDIT_TOKEN=
